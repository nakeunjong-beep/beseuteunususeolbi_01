rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all for maximum security
    match /{document=**} {
      allow read, write: if false;
    }

    // Global configuration for the top banner
    match /configs/banner {
      // Public read access so the custom banner loads instantly for everyone, on any device!
      allow read: if true;
      
      // Only the authorized super administrator (nakeunjong@gmail.com) is allowed to update/set the banner configuration
      allow write: if request.auth != null 
        && request.auth.token.email == 'nakeunjong@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // Customer service / leak counseling inquiry submissions
    match /submissions/{submissionId} {
      // Any public visitor can submit a service request (create)
      allow create: if true;
      
      // Only the authorized super administrator (nakeunjong@gmail.com) can read, update, or delete submissions
      allow read, update, delete: if request.auth != null 
        && request.auth.token.email == 'nakeunjong@gmail.com'
        && request.auth.token.email_verified == true;
    }
  }
}
